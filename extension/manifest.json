{
  "manifest_version": 3,
  "name": "タスク管理 - プロジェクト工程管理",
  "version": "1.2.0",
  "key": "",
  "description": "階層型タスク管理 + カンバン + ダッシュボード + Googleカレンダー連携",
  "action": {
    "default_icon": {
      "128": "icons/icon128.png"
    },
    "default_title": "タスク管理を開く"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://*.firebaseio.com https://*.googleapis.com wss://*.firebaseio.com"
  },
  "permissions": ["storage", "identity", "alarms", "notifications"],
  "oauth2": {
    "client_id": "439914640624-nmjf7v44o11em188eaumk6l8r661t6gs.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.events"
    ]
  }
}
